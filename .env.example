DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql+psycopg://user:password@host/dbname?sslmode=require
REDIS_URL=redis://localhost:6379/0

COMETAPI_API_KEY=your_cometapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# Gemini API — get key from https://aistudio.google.com
# Must have the Gemini API enabled in your Google Cloud project
GEMINI_API_KEY=your_gemini_api_key_here
# gemini-3.1-pro-preview for deep analysis, gemini-3.1-flash-lite-preview for speed
GEMINI_MODEL=gemini-3.1-pro-preview

SECRET_KEY=generate_with_openssl_rand_hex_32

CLAUDE_CREATIVE_MODEL=claude-opus-4-6
CLAUDE_FAST_MODEL=claude-sonnet-4-6
DEFAULT_IMAGE_MODEL=nanobananapro
DEFAULT_VIDEO_MODEL=kling3
JOB_FILES_DIR=./jobs
CELERY_CONCURRENCY=8
